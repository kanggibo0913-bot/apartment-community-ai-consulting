# OpenAI API 설정 (Netlify Functions에서 사용)
# 실제 키는 이 파일이 아니라 .env 파일 또는 Netlify 대시보드 환경변수로만 관리하세요.
# .env 파일은 .gitignore에 의해 git에 올라가지 않습니다.

# OpenAI API 키 (필수) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── taskType별 모델 라우팅 ──────────────────────────────────────
# 기본 모델 (선택) — 공문/계약서/안건 예측 등 일반 task에 사용.
# 미설정 시 OPENAI_MODEL(하위호환) → 코드 기본값(gpt-4.1-mini) 순으로 적용.
OPENAI_MODEL_DEFAULT=gpt-4.1-mini

# 월간 운영 리포트 전용 모델 (선택) — 일반 task보다 품질이 중요해 상위 모델 사용.
# 미설정 시 코드 기본값(gpt-4.1) 적용.
# ⚠️ gpt-5.5 등 추론형 모델은 동기 호출이 25초+라 Netlify 동기 함수 한도를 넘겨 사용 불가.
#    추론형을 쓰려면 비동기(백그라운드 함수+폴링) 구조가 필요함.
OPENAI_MODEL_MONTHLY_REPORT=gpt-4.1

# (하위호환) 기존 단일 모델 변수 — OPENAI_MODEL_DEFAULT가 없을 때만 사용됨
OPENAI_MODEL=gpt-4.1-mini

# ────────────────────────────────────────────────────────────
# Supabase 연동 (Netlify Functions 전용 서버 환경변수)
# 브라우저에 노출되면 안 되므로 VITE_ prefix를 절대 사용하지 마세요.
# 값은 Netlify 대시보드 환경변수 또는 로컬 .env 파일에만 설정합니다.
# .env 파일은 .gitignore에 의해 git에 올라가지 않습니다.
# ────────────────────────────────────────────────────────────

# Supabase 프로젝트 URL (예: https://xxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key — 절대 브라우저에 노출 금지.
# Netlify Function 안에서만 사용해 Supabase REST/SQL을 호출합니다.
SUPABASE_SERVICE_ROLE_KEY=
